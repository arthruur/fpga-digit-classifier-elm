# ─── Quartus build artifacts ────────────────────────────────────────────────

# Synthesis / P&R database (gerado automaticamente)
quartus/db/
quartus/incremental_db/

# Arquivos de saída da compilação (exceto bitstream e pin report)
quartus/output_files/*.rpt
quartus/output_files/*.summary
quartus/output_files/*.smsg
quartus/output_files/*.cdf
quartus/output_files/*.pin

# Simulação gerada
quartus/simulation/

# Relatórios de arquivo/restore (não relevantes para o projeto)
quartus/*.archive.rpt
quartus/*.restore.rpt

# Arquivos temporários e de log do Quartus
quartus/*.qarlog
quartus/c5_pin_model_dump.txt
quartus/qar_info.json
quartus/assignment_defaults.qdf
quartus/elm_accel_assignment_defaults.qdf

# Artefatos de output_files não essenciais
quartus/output_files/*.done
quartus/output_files/*.jditmp
quartus/output_files/*.sld
quartus/output_files/*.jdi

# Backups automáticos do Quartus
*.bak

# ─── Arquivos gerados pelos scripts Python ───────────────────────────────────
sim/

# ─── Manter no repositório ────────────────────────────────────────────────────
# quartus/output_files/elm_accel.sof  → bitstream compilado (rastrear)
# quartus/output_files/elm_accel.pin  → já ignorado acima (opcional: remover linha)
# quartus/*.qpf, *.qsf, *.sdc        → configuração do projeto
# quartus/*.qar                       → arquivo compactado do projeto
# quartus/*.hex                       → dados de inicialização de memória
