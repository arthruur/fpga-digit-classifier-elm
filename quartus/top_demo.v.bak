// =============================================================================
// top_demo.v — Top-level standalone para demo na DE1-SoC
// TEC 499 · MI Sistemas Digitais · UEFS 2026.1
//
// Operação:
//   1. Pressione KEY[0] para iniciar a inferência.
//      A imagem já está pré-carregada no bitstream (img_test.hex).
//   2. Durante o processamento, LEDR[0] acende (BUSY).
//   3. Ao concluir (~2 ms), LEDR[1] acende (DONE) e HEX0 exibe o dígito predito.
//   4. Se ocorrer erro de overflow, LEDR[2] acende (ERROR).
//   5. SW[0] = 1 mantém o sistema em reset; solte para operar.
//
// Conexões DE1-SoC:
//   CLOCK_50  → clk (50 MHz, pino AF14)
//   SW[0]     → reset (ativo ALTO: SW para cima = reset)
//   KEY[0]    → start (ativo BAIXO: pressionar = start)
//   LEDR[0]   → BUSY
//   LEDR[1]   → DONE
//   LEDR[2]   → ERROR
//   HEX0[6:0] → dígito predito (0..9), segmentos ativos em LOW
//
// Parâmetro INIT_FILE: caminho relativo ao projeto Quartus para o
// arquivo img_test.hex gerado pelo golden model (elm_golden.py).
// Exemplo: "../sim/img_test.hex"
// =============================================================================

module top_demo #(
    parameter INIT_FILE = "../sim/img_test.hex"
)(
    input        CLOCK_50,
    input        SW0,        // reset: SW para cima = reset ativo
    input        KEY0,       // start: pressionar (nível baixo) = start
    output [6:0] HEX0,       // display 7-segmentos (ativo em LOW)
    output       LEDR0,      // BUSY
    output       LEDR1,      // DONE
    output       LEDR2       // ERROR
);

    // =========================================================================
    // Sinais internos
    // =========================================================================
    wire        rst_n  = ~SW0;    // SW0=1 → reset ativo; SW0=0 → operação normal

    // -------------------------------------------------------------------------
    // Debounce e detecção de borda do KEY[0]
    //
    // KEY[0] é ativo-baixo na DE1-SoC. O debounce usa um contador de 20 bits
    // (~20 ms a 50 MHz) para filtrar bouncing mecânico.
    // O pulso de start é gerado na borda de descida (KEY0 vai de 1 para 0).
    // -------------------------------------------------------------------------
    reg [19:0] debounce_cnt;
    reg        key_stable;      // nível estabilizado após debounce
    reg        key_prev;        // amostra do ciclo anterior (para detecção de borda)
    wire       start_pulse;     // pulso de 1 ciclo na borda de descida de KEY0

    always @(posedge CLOCK_50 or negedge rst_n) begin
        if (!rst_n) begin
            debounce_cnt <= 0;
            key_stable   <= 1'b1;   // KEY solto = nível alto
            key_prev     <= 1'b1;
        end else begin
            // Conta enquanto KEY0 difere do estado estabilizado
            if (KEY0 !== key_stable)
                debounce_cnt <= debounce_cnt + 1;
            else
                debounce_cnt <= 0;

            // Quando o contador transborda (~20 ms), atualiza o estado estável
            if (debounce_cnt == 20'hFFFFF)
                key_stable <= KEY0;

            key_prev <= key_stable;
        end
    end

    // Borda de descida: key_stable estava em 1 e foi para 0 (KEY pressionado)
    assign start_pulse = key_prev & ~key_stable;

    // =========================================================================
    // Instância do elm_accel com imagem pré-carregada
    //
    // - INIT_FILE: o Quartus inicializa o M10K da ram_img com img_test.hex
    // - PRELOADED_IMG=1: a FSM pula LOAD_IMG e vai direto a CALC_HIDDEN
    // - Interface MMIO não usada neste modo: addr=0, write_en=0, read_en=0
    // =========================================================================
    wire [31:0] mmio_data_out;  // não usado — leitura MMIO desabilitada
    wire [31:0] mmio_data_in  = 32'b0;
    wire [31:0] mmio_addr     = 32'b0;

    // Sinais de status lidos via MMIO internamente pelo reg_bank
    // Para o top_demo, acessamos os sinais diretamente via instância nomeada.
    // Como o reg_bank encapsula status/result, usamos read_en para STATUS.
    // Estratégia: leitura contínua de STATUS — addr fixo em 0x04, read_en=1.
    wire [31:0] status_word;

    elm_accel #(
        .INIT_FILE     (INIT_FILE),
        .PRELOADED_IMG (1)
    ) u_elm (
        .clk      (CLOCK_50),
        .rst_n    (rst_n),
        // START via KEY: escrevemos 0x01 no CTRL quando start_pulse=1
        .addr     (start_pulse ? 32'h00 : 32'h04),
        .write_en (start_pulse),
        .read_en  (~start_pulse),
        .data_in  (start_pulse ? 32'h01 : 32'h00),
        .data_out (status_word)
    );

    // =========================================================================
    // Decodificação do STATUS
    //
    // STATUS (offset 0x04):
    //   bits[1:0] = estado: 00=IDLE, 01=BUSY, 10=DONE, 11=ERROR
    //   bits[5:2] = pred:   dígito predito (0..9), válido quando DONE
    // =========================================================================
    wire [1:0] fsm_state = status_word[1:0];
    wire [3:0] pred      = status_word[5:2];

    assign LEDR0 = (fsm_state == 2'b01);   // BUSY
    assign LEDR1 = (fsm_state == 2'b10);   // DONE
    assign LEDR2 = (fsm_state == 2'b11);   // ERROR

    // =========================================================================
    // Decoder 7-segmentos
    //
    // Display de cátodo comum com segmentos ativos em nível BAIXO (0 = aceso).
    // Segmentos: {g, f, e, d, c, b, a} = HEX0[6:0]
    //
    //   ─ a ─
    //  f     b
    //   ─ g ─
    //  e     c
    //   ─ d ─
    //
    // Quando DONE=0 (IDLE ou BUSY), exibe traço central (só segmento g).
    // Quando DONE=1, exibe o dígito predito.
    // =========================================================================
    reg [6:0] seg;

    always @(*) begin
        if (fsm_state == 2'b10) begin
            // DONE: exibe dígito predito
            case (pred)
                4'd0:    seg = 7'b1000000;  // 0
                4'd1:    seg = 7'b1111001;  // 1
                4'd2:    seg = 7'b0100100;  // 2
                4'd3:    seg = 7'b0110000;  // 3
                4'd4:    seg = 7'b0011001;  // 4
                4'd5:    seg = 7'b0010010;  // 5
                4'd6:    seg = 7'b0000010;  // 6
                4'd7:    seg = 7'b1111000;  // 7
                4'd8:    seg = 7'b0000000;  // 8
                4'd9:    seg = 7'b0010000;  // 9
                default: seg = 7'b0111111;  // traço (erro inesperado)
            endcase
        end else begin
            // IDLE / BUSY / ERROR: traço central (segmento g aceso)
            seg = 7'b0111111;
        end
    end

    assign HEX0 = seg;

endmodule